---
extends: default

ignore: |
  .venv/
  venv/
  .ansible/

rules:
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  document-start:
    present: true
  line-length:
    max: 160
    level: warning
  truthy: disable
